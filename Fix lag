local Workspace = game:GetService("Workspace")
local Lighting = game:GetService("Lighting")
local Terrain = Workspace.Terrain
local StarterGui = game:GetService("StarterGui")

pcall(function()
    StarterGui:SetCore("SendNotification", {
        Title = "fix lag",
        Text = "Optimizing...",
        Duration = 5
    })
end)

pcall(function()
    settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
    UserSettings():GetService("UserGameSettings").SavedQualityLevel = Enum.SavedQualitySetting.QualityLevel1
end)

Lighting.GlobalShadows = false
Lighting.FogEnd = 9e9
Lighting.Brightness = 0
Lighting.ClockTime = 12

Terrain.WaterWaveSize = 0
Terrain.WaterWaveSpeed = 0
Terrain.WaterReflectance = 0
Terrain.WaterTransparency = 1
pcall(function() Terrain.Decoration = false end)

local function OptimizeMax(obj)
    pcall(function()
        if obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Beam") or obj:IsA("Fire") or obj:IsA("Smoke") or obj:IsA("Sparkles") or obj:IsA("Cloud") or obj:IsA("Explosion") then
            obj.Enabled = false
            obj:Destroy()
        elseif obj:IsA("PostEffect") or obj:IsA("BloomEffect") or obj:IsA("BlurEffect") or obj:IsA("ColorCorrectionEffect") or obj:IsA("SunRaysEffect") or obj:IsA("DepthOfFieldEffect") or obj:IsA("Atmosphere") then
            obj.Enabled = false
            obj:Destroy()
        elseif obj:IsA("Decal") or obj:IsA("Texture") then
            obj.Transparency = 1
            obj:Destroy()
        elseif obj:IsA("PointLight") or obj:IsA("SpotLight") or obj:IsA("SurfaceLight") then
            obj.Enabled = false
            obj:Destroy()
        elseif obj:IsA("BasePart") then
            obj.Material = Enum.Material.SmoothPlastic
            obj.Reflectance = 0
            obj.CastShadow = false
        elseif obj:IsA("MeshPart") then
            obj.Material = Enum.Material.SmoothPlastic
            obj.Reflectance = 0
            obj.CastShadow = false
            obj.TextureID = ""
        elseif obj:IsA("SpecialMesh") then
            obj.TextureId = ""
        end
    end)
end

task.spawn(function()
    for _, obj in pairs(Lighting:GetDescendants()) do
        OptimizeMax(obj)
    end
    for _, obj in pairs(Workspace:GetDescendants()) do
        OptimizeMax(obj)
    end
end)

Workspace.DescendantAdded:Connect(OptimizeMax)
Lighting.DescendantAdded:Connect(OptimizeMax)
